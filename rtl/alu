module alu(
    input  logic [31:0] a, b,
    input  logic [2:0]  alu_ctrl,
    output logic [31:0] result,
    output logic        zero
);

    always_comb begin
        case (alu_ctrl)
            3'b000: result = a + b; // ADD
            3'b001: result = a - b; // SUB
            default: result = 32'b0;
        endcase
    end

    assign zero = (result == 0);

endmodule

